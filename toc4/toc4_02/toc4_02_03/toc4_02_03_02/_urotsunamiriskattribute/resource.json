        "hasXMLIdentifier",
        "_cdaef7b6-01a0-0b51-7a6f-6bb6a8ac50f7"
    ],
    [
        "urn:metanorma-xml-id:_cdaef7b6-01a0-0b51-7a6f-6bb6a8ac50f7",
