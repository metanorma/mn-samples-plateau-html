        "type",
        "link"
    ],
    [
        "urn:uuid:8063fa62-6efb-4c23-8a58-c6eaa470ef54",
        "hasTarget",
        "https://www.mlit.go.jp/sogoseisaku/point/content/001621078.pdf"
    ],
    [
        "urn:uuid:8063fa62-6efb-4c23-8a58-c6eaa470ef54",
        "hasPart",
        "[23]"
    ],
    [
        "urn:metanorma-xml-id:_53fd5a19-d63c-a0ed-d6f4-4e2594c6b9ef",
        "hasPart",
        "』参照）である。"
    ],
    [
        "urn:metanorma-xml-id:_53fd5a19-d63c-a0ed-d6f4-4e2594c6b9ef",
        "hasPart",
        " uro:rank又はuro:rankOrgのいずれか一つをもつ。"
