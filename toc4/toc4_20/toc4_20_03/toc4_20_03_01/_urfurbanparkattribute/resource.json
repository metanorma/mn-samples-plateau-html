        "urn:metanorma-xml-id:_158b9858-f4fa-0d41-c5b2-c810b8b5976c",
        "hasPart",
        "都市公園法第２条第１項で定義する都市公園に関する情報を定義したデータ型。"
    ],
    [
        "urn:uuid:63c39ee2-9979-47e6-83f4-5f84e49f893e",
        "hasPart",
        "\n\n"
    ],
    [
